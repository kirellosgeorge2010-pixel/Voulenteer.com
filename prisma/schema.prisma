// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  role          String    @default("STUDENT") // STUDENT, ORGANIZATION, ADMIN
  image         String?
  createdAt     DateTime  @default(now())

  // Student specific fields (could be in a separate Profile model, but kept here for simplicity)
  age           Int?
  country       String?
  skills        String?   // Stored as JSON string
  interests     String?   // Stored as JSON string
  resumeUrl     String?
  certificates  String?   // Stored as JSON string

  // Relations
  organization  Organization?
  applications  Application[]
  reviews       Review[]
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Organization {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  logo        String?
  website     String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  opportunities Opportunity[]
  reviews       Review[]
}

model Opportunity {
  id             String   @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id])
  title          String
  description    String
  category       String   // Volunteering, Internship, Workshop, etc.
  location       String?
  isRemote       Boolean  @default(false)
  isPaid         Boolean  @default(false)
  date           DateTime?
  deadline       DateTime?
  requiredSkills String?  // Stored as JSON string
  seatsTotal     Int?
  seatsAvailable Int?
  bannerImage    String?
  createdAt      DateTime @default(now())

  applications   Application[]
  reviews        Review[]
}

model Application {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  status        String   @default("PENDING") // PENDING, REVIEWING, ACCEPTED, REJECTED
  appliedAt     DateTime @default(now())

  @@unique([userId, opportunityId])
}

model Review {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String
  attachment String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}
